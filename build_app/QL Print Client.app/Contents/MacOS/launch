#!/bin/bash
# Launcher for QL Print Client
DIR="$(cd "$(dirname "$0")" && pwd)"

# Start the print client server in background
"$DIR/ql-print-client" --port 7010 --no-browser &
SERVER_PID=$!

# Wait for server to be ready
for i in $(seq 1 20); do
    if curl -s http://localhost:7010/api/status > /dev/null 2>&1; then
        break
    fi
    sleep 0.5
done

# Open dashboard in default browser
open http://localhost:7010

# Keep script alive — when this exits, the server exits too
wait $SERVER_PID
